<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,user-scalable=no">
<title>INSECTILES: Apex Swarm Edition</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
html,body{width:100%;height:100%;overflow:hidden;background:#000;user-select:none;-webkit-user-select:none;touch-action:none}
canvas{position:fixed;top:0;left:0}
:root{
  --green:#00ff88;--gold:#ffd700;--red:#ff3333;--cyan:#88ffff;--purple:#aa88ff;
  --green2:#00cc66;--red2:#cc2200;
  --bg1:rgba(0,0,0,.9);--bg2:rgba(0,0,8,.95);
  --font-game:'Orbitron',monospace;--font-mono:'Share Tech Mono',monospace;
}

/* ── SCREEN SYSTEM ─────────────────────────────────────────────── */
.screen{position:fixed;inset:0;display:none;flex-direction:column;align-items:center;
  justify-content:center;z-index:100;padding:20px}
.screen.on{display:flex}
#sMenu{background:var(--bg1)}
#sClass{background:var(--bg2);overflow-y:auto}
#sHtp{background:var(--bg2);overflow-y:auto}
#sSettings{background:var(--bg2);overflow-y:auto}
#sRecords{background:var(--bg2);overflow-y:auto}
#sLevelup{background:rgba(0,0,10,.94);z-index:200}
#sPause{background:rgba(0,0,0,.88);z-index:250}
#sGameover{background:rgba(0,0,0,.95);z-index:150}

/* ── ANIMATIONS ────────────────────────────────────────────────── */
@keyframes synPop{from{transform:translate(-50%,-50%) scale(.3);opacity:0}60%{transform:translate(-50%,-50%) scale(1.08)}to{transform:translate(-50%,-50%) scale(1);opacity:1}}
@keyframes waveIn{from{transform:translate(-50%,-50%) scale(.5);opacity:0}50%{transform:translate(-50%,-50%) scale(1.1);opacity:1}80%{opacity:1}to{transform:translate(-50%,-50%) scale(1.2);opacity:0}}
@keyframes fadeIn{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
@keyframes pulse{0%,100%{opacity:.7}50%{opacity:1}}
.anim-in{animation:fadeIn .35s ease forwards}

/* ── TYPOGRAPHY ─────────────────────────────────────────────────── */
.t-title{font-family:var(--font-game);font-weight:900;color:var(--green);letter-spacing:8px;
  text-shadow:0 0 40px #00ff8866,0 0 80px #00ff8822;font-size:clamp(2rem,6vw,4rem)}
.t-sub{font-family:var(--font-mono);font-size:.82rem;color:#44aa77;letter-spacing:5px;opacity:.8}
.t-label{font-family:var(--font-mono);font-size:.72rem;color:#5a7a6a;letter-spacing:3px}
.t-section{font-family:var(--font-game);font-size:1.1rem;font-weight:700;color:var(--green);
  letter-spacing:4px;margin-bottom:16px;padding-bottom:8px;border-bottom:1px solid #00ff8833}
.t-dim{font-family:var(--font-mono);font-size:.7rem;color:#445566}

/* ── BUTTONS ────────────────────────────────────────────────────── */
.btn{font-family:var(--font-game);font-size:.9rem;font-weight:700;letter-spacing:3px;
  padding:13px 38px;background:transparent;border:2px solid var(--green);color:var(--green);
  cursor:pointer;transition:all .18s;clip-path:polygon(12px 0%,100% 0%,calc(100% - 12px) 100%,0% 100%);
  margin:5px;display:inline-block}
.btn:hover{background:#00ff8820;box-shadow:0 0 22px #00ff8844;transform:translateY(-2px) scale(1.03)}
.btn:active{transform:scale(.97);transition:transform .05s}
.btn.sm{font-size:.72rem;padding:9px 24px;letter-spacing:2px}
.btn.red{border-color:var(--red);color:var(--red)}.btn.red:hover{background:#ff333318}
.btn.gold{border-color:var(--gold);color:var(--gold)}.btn.gold:hover{background:#ffd70018}
.btn.cyan{border-color:var(--cyan);color:var(--cyan)}.btn.cyan:hover{background:#88ffff18}
.btn[disabled]{opacity:.3;pointer-events:none}

/* ── MAIN MENU ──────────────────────────────────────────────────── */
#menuNav{display:flex;flex-direction:column;align-items:center;gap:4px;margin-top:8px}
#menuAmber{font-family:var(--font-game);font-size:.85rem;color:var(--gold);margin:12px 0;opacity:.8}
#menuControls{font-family:var(--font-mono);color:#334;font-size:.65rem;letter-spacing:2px;margin-top:16px;line-height:2;text-align:center}

/* ── CLASS SELECT ───────────────────────────────────────────────── */
.class-grid{display:flex;gap:14px;flex-wrap:wrap;justify-content:center;margin:16px 0;max-width:940px}
.ccard{width:153px;min-height:215px;border:2px solid;padding:16px 10px;cursor:pointer;
  transition:all .2s;text-align:center;background:rgba(0,0,0,.55);
  clip-path:polygon(10px 0%,100% 0%,calc(100% - 10px) 100%,0% 100%)}
.ccard:hover{transform:translateY(-6px) scale(1.03);filter:brightness(1.4);box-shadow:0 10px 32px rgba(0,0,0,.5)}
.ccard h3{font-family:var(--font-game);font-size:.75rem;font-weight:700;letter-spacing:2px;margin-bottom:3px}
.ccard .crole{font-family:var(--font-mono);font-size:.6rem;opacity:.55;margin-bottom:8px}
.ccard .cicon{font-size:2.2rem;margin-bottom:8px;display:block}
.ccard .cabil{font-family:var(--font-mono);font-size:.58rem;opacity:.8;margin-bottom:5px}
.ccard .cdesc{font-family:var(--font-mono);font-size:.55rem;opacity:.48;line-height:1.4}
.cstat-row{display:grid;grid-template-columns:1fr 1fr;gap:1px;margin-top:9px;
  font-family:var(--font-mono);font-size:.55rem;color:#4a5a6a}
.ccard .cbest{font-family:var(--font-mono);font-size:.52rem;margin-top:8px;opacity:.7}

/* ── SETTINGS ───────────────────────────────────────────────────── */
.settings-wrap{width:100%;max-width:560px}
.srow{display:flex;align-items:center;justify-content:space-between;margin-bottom:22px;gap:16px}
.srow-label{font-family:var(--font-mono);font-size:.78rem;color:#aab8cc;letter-spacing:2px;min-width:140px}
.sval{font-family:var(--font-game);font-size:.75rem;font-weight:700;color:var(--green);min-width:36px;text-align:right}
input[type=range]{-webkit-appearance:none;appearance:none;flex:1;height:4px;background:#1a3a2a;
  border-radius:2px;outline:none;cursor:pointer}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:18px;height:18px;
  border-radius:50%;background:var(--green);border:2px solid #001a0a;cursor:pointer;transition:transform .15s}
input[type=range]::-webkit-slider-thumb:hover{transform:scale(1.2)}
.toggle-wrap{display:flex;gap:0}
.tgl{font-family:var(--font-mono);font-size:.68rem;padding:7px 16px;border:1px solid #1a3a2a;
  color:#446655;cursor:pointer;transition:all .15s;letter-spacing:1px}
.tgl:first-child{border-radius:4px 0 0 4px}.tgl:last-child{border-radius:0 4px 4px 0}
.tgl.on{background:var(--green);color:#001a0a;border-color:var(--green);font-weight:700}
.settings-section{font-family:var(--font-game);font-size:.7rem;color:#334;letter-spacing:3px;
  margin:20px 0 14px;padding-bottom:6px;border-bottom:1px solid #0a1a0f}

/* ── HOW TO PLAY ────────────────────────────────────────────────── */
.htp-wrap{max-width:800px;width:100%}
.htp-tabs{display:flex;gap:0;margin-bottom:24px;flex-wrap:wrap}
.htab{font-family:var(--font-game);font-size:.65rem;padding:9px 18px;border:1px solid #1a3a2a;
  color:#446655;cursor:pointer;transition:all .15s;letter-spacing:2px}
.htab.on{background:var(--green);color:#001a0a;border-color:var(--green);font-weight:700}
.htab-panel{display:none;animation:fadeIn .2s ease}.htab-panel.on{display:block}
.htp-class-card{border:1px solid #0a2a18;padding:14px 18px;margin-bottom:12px;background:rgba(0,255,136,.03);border-radius:2px}
.htp-class-header{display:flex;align-items:center;gap:12px;margin-bottom:10px}
.htp-class-icon{font-size:1.8rem}
.htp-class-info h3{font-family:var(--font-game);font-size:.78rem;font-weight:700;letter-spacing:2px}
.htp-class-info .crole{font-family:var(--font-mono);font-size:.6rem;opacity:.5;margin-top:2px}
.htp-stat-bars{display:grid;grid-template-columns:1fr 1fr;gap:4px 16px;margin:8px 0}
.stat-bar-row{display:flex;align-items:center;gap:8px;font-family:var(--font-mono);font-size:.6rem;color:#5a7a6a}
.stat-bar-track{flex:1;height:5px;background:#0a1a0f;border-radius:3px;overflow:hidden}
.stat-bar-fill{height:100%;border-radius:3px;transition:width .4s}
.htp-abil{font-family:var(--font-mono);font-size:.65rem;color:#88ffcc;margin-top:8px;padding:6px 10px;
  background:rgba(0,255,136,.06);border-left:2px solid var(--green)}
.htp-tip{font-family:var(--font-mono);font-size:.62rem;color:#5a7a6a;margin-top:6px}
.key-table{border-collapse:collapse;width:100%;font-family:var(--font-mono)}
.key-table td{padding:7px 12px;font-size:.72rem;border-bottom:1px solid #0a1a0f}
.key-table td:first-child{color:var(--green);font-family:var(--font-game);font-size:.65rem;white-space:nowrap}
.key-table td:last-child{color:#889aaa}
.syn-card{border:1px solid;padding:12px 16px;margin-bottom:10px;border-radius:2px}
.syn-req{font-family:var(--font-mono);font-size:.62rem;opacity:.7;margin-top:6px}

/* ── RECORDS ────────────────────────────────────────────────────── */
.records-wrap{max-width:620px;width:100%}
.rec-row{display:flex;justify-content:space-between;align-items:center;
  padding:9px 0;border-bottom:1px solid #0a1a0f;font-family:var(--font-mono)}
.rec-row .rk{font-size:.7rem;color:#5a7a6a;letter-spacing:2px}
.rec-row .rv{font-size:.82rem;font-family:var(--font-game);font-weight:700;color:var(--green)}
.rec-class-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(165px,1fr));gap:10px;margin-top:14px}
.rec-class-card{border:1px solid;padding:10px 12px;text-align:center;border-radius:2px;background:rgba(0,0,0,.4)}
.rec-class-card .ci{font-size:1.5rem;margin-bottom:4px}
.rec-class-card .cn{font-family:var(--font-game);font-size:.6rem;font-weight:700;letter-spacing:1px}
.rec-class-card .cs{font-family:var(--font-mono);font-size:.68rem;margin-top:4px}

/* ── HUD ────────────────────────────────────────────────────────── */
#hud{position:fixed;top:0;left:0;width:100%;padding:11px 16px;display:none;z-index:50;pointer-events:none}
.hbar-wrap{display:flex;align-items:center;gap:7px;margin-bottom:4px}
.hlabel{font-family:var(--font-mono);font-size:.68rem;color:#445566;min-width:20px}
.htrack{width:180px;height:10px;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.1);border-radius:5px;overflow:hidden}
.hfill{height:100%;border-radius:5px;transition:width .1s}
.hp-fill{background:linear-gradient(90deg,#dd2222,#ff6666)}
.xp-fill{background:linear-gradient(90deg,#00bb55,#66ffaa)}
.hval{font-family:var(--font-mono);font-size:.6rem;min-width:70px;color:#778899}
#hudR{position:fixed;top:11px;right:16px;text-align:right;pointer-events:none;z-index:50}
#hudTimer{font-family:var(--font-game);font-size:1.45rem;font-weight:700;color:var(--green)}
#hudWave{font-family:var(--font-mono);font-size:.72rem;color:#ffaa44;margin-top:1px}
#hudScore{font-family:var(--font-mono);font-size:.67rem;color:#6688aa}
#hudBest{font-family:var(--font-mono);font-size:.58rem;color:#334455;margin-top:1px}
#hudStreak{font-family:var(--font-game);font-size:.68rem;font-weight:700;margin-top:3px}
#hudSyns{margin-top:5px;font-size:.6rem;line-height:1.8;font-family:var(--font-mono)}
#abilInd{position:fixed;bottom:20px;left:50%;transform:translateX(-50%);
  font-family:var(--font-mono);font-size:.72rem;text-align:center;padding:6px 18px;
  border:1px solid;border-radius:3px;pointer-events:none;z-index:50;
  transition:color .25s,border-color .25s,background .25s;white-space:nowrap}
#volHud{position:fixed;bottom:52px;right:16px;font-family:var(--font-mono);font-size:.6rem;
  color:#334;pointer-events:none;z-index:50;display:none;text-align:right;line-height:2}

/* ── LEVEL UP ───────────────────────────────────────────────────── */
.upg-cards{display:flex;gap:18px;flex-wrap:wrap;justify-content:center;max-width:760px}
.ucrd{width:188px;border:2px solid var(--gold);padding:20px 16px;cursor:pointer;
  text-align:center;background:rgba(255,215,0,.04);transition:all .2s;
  clip-path:polygon(12px 0%,100% 0%,calc(100% - 12px) 100%,0% 100%)}
.ucrd:hover{background:rgba(255,215,0,.13);transform:translateY(-6px);box-shadow:0 0 26px rgba(255,215,0,.3)}
.ucrd:active{transform:translateY(-2px)}
.ucrd .uicon{font-size:2.2rem;margin-bottom:8px}
.ucrd .uname{font-family:var(--font-game);font-size:.72rem;font-weight:700;color:var(--gold);margin-bottom:5px;letter-spacing:1px}
.ucrd .udesc{font-family:var(--font-mono);font-size:.64rem;color:#aaa;line-height:1.35}
.ucrd .ulvl{margin-top:7px;font-family:var(--font-mono);font-size:.58rem;color:#ffd70055}

/* ── PAUSE ──────────────────────────────────────────────────────── */
#pauseTitle{font-family:var(--font-game);font-size:2.4rem;font-weight:900;
  color:var(--cyan);letter-spacing:8px;margin-bottom:28px;text-shadow:0 0 30px #88ffff44}
#pauseStats{font-family:var(--font-mono);font-size:.72rem;color:#446655;margin-bottom:22px;line-height:2;text-align:center}

/* ── GAME OVER ──────────────────────────────────────────────────── */
.go-title{font-family:var(--font-game);font-size:clamp(2rem,5vw,3rem);font-weight:900;
  letter-spacing:8px;margin-bottom:18px;text-align:center}
.go-stats{font-family:var(--font-mono);color:#7a8a9a;line-height:2.1;margin-bottom:16px;text-align:center;font-size:.88rem}
.go-amber{font-family:var(--font-game);font-size:1.1rem;color:var(--gold);margin-bottom:22px;text-align:center}
.go-best{font-family:var(--font-mono);font-size:.72rem;margin-bottom:16px;text-align:center}

/* ── OVERLAYS ───────────────────────────────────────────────────── */
#synNotif{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);
  background:rgba(0,0,10,.97);padding:24px 44px;text-align:center;
  display:none;z-index:310;pointer-events:none;border-radius:3px;min-width:260px}
#waveBanner{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);
  pointer-events:none;z-index:290;display:none;text-align:center}

/* ── TOUCH ──────────────────────────────────────────────────────── */
#joyArea{position:fixed;bottom:28px;left:28px;width:120px;height:120px;z-index:61;display:none}
#joyOut{width:120px;height:120px;border-radius:50%;border:2px solid rgba(0,255,136,.2);background:rgba(0,0,0,.4);position:relative}
#joyKnob{width:42px;height:42px;border-radius:50%;background:rgba(0,255,136,.32);position:absolute;top:39px;left:39px;pointer-events:none}
#abilBtn{position:fixed;bottom:48px;right:28px;width:78px;height:78px;border-radius:50%;
  border:2px solid rgba(136,255,255,.55);background:rgba(136,255,255,.1);
  font-family:var(--font-game);font-size:.52rem;font-weight:700;color:var(--cyan);
  z-index:61;display:none;cursor:pointer;text-align:center;line-height:1.2;padding-top:20px;letter-spacing:1px}

/* ── RESPONSIVE ─────────────────────────────────────────────────── */
@media(max-width:700px){
  .class-grid{gap:9px}.ccard{width:138px;min-height:195px;padding:13px 8px}
  .upg-cards{gap:12px}.ucrd{width:155px;padding:16px 12px}
  #joyArea,#abilBtn{display:block}
  .htp-tabs{gap:2px}
}
</style>
</head>
<body>
<canvas id="canvas"></canvas>

<!-- ═══ SCREENS ═══════════════════════════════════════════════════ -->

<!-- MAIN MENU -->
<div id="sMenu" class="screen on">
  <div class="t-title" style="margin-bottom:4px">INSECTILES</div>
  <div class="t-sub" style="margin-bottom:36px">◆ APEX SWARM EDITION ◆</div>
  <div id="menuNav">
    <button class="btn" id="btnPlay" style="width:240px;font-size:1.05rem;padding:16px">▶ ENTER THE SWARM</button>
    <button class="btn sm cyan" id="btnHtp"   style="width:240px">HOW TO PLAY</button>
    <button class="btn sm"      id="btnSettings" style="width:240px;border-color:#5a7a6a;color:#5a7a6a">⚙ SETTINGS</button>
    <button class="btn sm"      id="btnRecords"  style="width:240px;border-color:#5a7a6a;color:#5a7a6a">🏆 RECORDS</button>
  </div>
  <div id="menuAmber"></div>
  <div id="menuControls">WASD / ARROWS: MOVE &nbsp;·&nbsp; AUTO-ATTACK &nbsp;·&nbsp; SPACE: ABILITY &nbsp;·&nbsp; ESC: PAUSE</div>
</div>

<!-- CLASS SELECT -->
<div id="sClass" class="screen">
  <div class="t-title" style="font-size:1.75rem;margin-bottom:2px">CHOOSE YOUR CLASS</div>
  <div class="t-sub" style="margin-bottom:18px;font-size:.7rem">CLICK TO PLAY — STATS SHOW BASE VALUES</div>
  <div class="class-grid" id="classGrid"></div>
  <button class="btn sm red" id="btnBackMenu2" style="margin-top:12px">← BACK</button>
</div>

<!-- HOW TO PLAY -->
<div id="sHtp" class="screen">
  <div class="t-title" style="font-size:1.7rem;margin-bottom:20px">HOW TO PLAY</div>
  <div class="htp-wrap">
    <div class="htp-tabs">
      <button class="htab on" data-tab="htpControls">CONTROLS</button>
      <button class="htab"    data-tab="htpClasses">CLASSES</button>
      <button class="htab"    data-tab="htpSynergies">SYNERGIES</button>
      <button class="htab"    data-tab="htpTips">TIPS</button>
    </div>
    <!-- Controls -->
    <div id="htpControls" class="htab-panel on">
      <table class="key-table">
        <tr><td>W A S D / ↑ ↓ ← →</td><td>Move your insect warrior</td></tr>
        <tr><td>SPACE</td><td>Activate class ability (watch the cooldown bar)</td></tr>
        <tr><td>ESC</td><td>Pause / resume the run</td></tr>
        <tr><td>M</td><td>Toggle music on/off</td></tr>
        <tr><td>[ / ]</td><td>Decrease / increase SFX volume</td></tr>
      </table>
      <div style="margin-top:20px" class="t-section">GAME LOOP</div>
      <div style="font-family:var(--font-mono);font-size:.7rem;color:#667788;line-height:1.9">
        • Enemies spawn in endless waves from all sides<br>
        • You <b style="color:#88ffcc">auto-attack</b> the nearest enemy in range<br>
        • Killing enemies drops <b style="color:#00ff88">XP gems</b> — walk over them to collect<br>
        • Level up to choose <b style="color:#ffd700">upgrades</b> — 3 random choices per level<br>
        • Stack matching upgrades to unlock <b style="color:#ff88cc">SYNERGIES</b> — game-changers<br>
        • Every 5 waves a <b style="color:#ff2200">BOSS</b> spawns — survive or die<br>
        • Earn <b style="color:#ffaa00">AMBER</b> to track your progress across runs
      </div>
    </div>
    <!-- Classes -->
    <div id="htpClasses" class="htab-panel" id="htpClassesPanel"></div>
    <!-- Synergies -->
    <div id="htpSynergies" class="htab-panel" id="htpSynPanel"></div>
    <!-- Tips -->
    <div id="htpTips" class="htab-panel">
      <div style="font-family:var(--font-mono);font-size:.72rem;color:#667788;line-height:2.1">
        🟢 &nbsp;<b style="color:#88ffcc">Don't stop moving.</b> Standing still is death at high waves.<br>
        🟡 &nbsp;<b style="color:#ffd700">Use your ability off cooldown.</b> Saving it for "the right moment" loses runs.<br>
        🔴 &nbsp;<b style="color:#ff8888">Kill Shamans first.</b> They heal all nearby enemies — let them live and elites become immortal.<br>
        🟣 &nbsp;<b style="color:#cc88ff">Chain kills for streak bonus.</b> 5x+ streak multiplies score. Keep the kills flowing.<br>
        ⚪ &nbsp;<b style="color:#aabbcc">Gems come to you.</b> Walk near them and they magnet in. Don't chase; let them collect naturally.<br>
        🔵 &nbsp;<b style="color:#88aaff">Boss waves are every 5.</b> Check the wave counter and prepare (full ability CD reset tip: use ability just before wave ticks).<br>
        🟠 &nbsp;<b style="color:#ffaa44">Iron Hide + Thorns is overpowered on Scarab.</b> Take damage → deal damage. Stack both to cap.<br>
        🟢 &nbsp;<b style="color:#88ffcc">Venom Lord is the strongest synergy.</b> Every kill poisons everything nearby. At high levels it's a chain reaction across the entire screen.
      </div>
    </div>
  </div>
  <button class="btn sm red" id="btnBackHtp" style="margin-top:20px">← BACK</button>
</div>

<!-- SETTINGS -->
<div id="sSettings" class="screen">
  <div class="t-title" style="font-size:1.7rem;margin-bottom:24px">⚙ SETTINGS</div>
  <div class="settings-wrap">
    <div class="settings-section">AUDIO</div>
    <div class="srow"><span class="srow-label">MASTER VOLUME</span><input type="range" id="slMaster" min="0" max="100" value="80"><span class="sval" id="valMaster">80</span></div>
    <div class="srow"><span class="srow-label">MUSIC</span><input type="range" id="slMusic" min="0" max="100" value="50"><span class="sval" id="valMusic">50</span></div>
    <div class="srow"><span class="srow-label">SFX</span><input type="range" id="slSfx" min="0" max="100" value="80"><span class="sval" id="valSfx">80</span></div>
    <div class="settings-section">DISPLAY</div>
    <div class="srow">
      <span class="srow-label">SCREEN SHAKE</span>
      <div class="toggle-wrap">
        <button class="tgl on" id="tglShakeOn"  data-group="shake" data-val="1">ON</button>
