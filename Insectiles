        <div class="syn-req">Requires: ${reqs}</div>`;
      synPanel.appendChild(d);
    });
  }
}

// ─── Records Screen ───────────────────────────────────────────────
function buildRecords(){
  const el=DOM.recordsContent;el.innerHTML='';
  const m=Math.floor(saveData.bestTime/60),s=Math.floor(saveData.bestTime%60);
  const rows=[
    ['BEST SCORE',    saveData.bestScore>0?saveData.bestScore.toLocaleString():'—'],
    ['BEST SURVIVAL', saveData.bestTime>0?`${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`:'—'],
    ['TOTAL AMBER',   saveData.amber.toLocaleString()],
    ['TOTAL RUNS',    saveData.totalRuns.toLocaleString()],
    ['TOTAL KILLS',   saveData.totalKills.toLocaleString()],
  ];
  rows.forEach(([k,v])=>{
    const r=document.createElement('div');r.className='rec-row';
    r.innerHTML=`<span class="rk">${k}</span><span class="rv">${v}</span>`;
    el.appendChild(r);
  });
  if(Object.keys(saveData.classBest).length>0){
    const h=document.createElement('div');h.className='t-section';h.style.marginTop='20px';h.textContent='CLASS RECORDS';el.appendChild(h);
    const grid=document.createElement('div');grid.className='rec-class-grid';
    Object.entries(CLASSES).forEach(([k,c])=>{
      const best=saveData.classBest[k];
      const d=document.createElement('div');d.className='rec-class-card';d.style.borderColor=c.color+'55';
      d.innerHTML=`<div class="ci">${c.icon}</div><div class="cn" style="color:${c.color}">${c.name}</div><div class="cs" style="color:${c.color}88">${best?best.toLocaleString():'No runs'}</div>`;
      grid.appendChild(d);
    });
    el.appendChild(grid);
  }else{
    const none=document.createElement('div');none.style.cssText='font-family:var(--font-mono);font-size:.72rem;color:#334;text-align:center;margin-top:20px';none.textContent='No runs completed yet. Get out there!';el.appendChild(none);
  }
}

// ─── Settings UI ──────────────────────────────────────────────────
function applySettingsUI(){
  $('slMaster').value=config.masterVol;$('valMaster').textContent=config.masterVol;
  $('slMusic').value=config.musicVol;  $('valMusic').textContent=config.musicVol;
  $('slSfx').value=config.sfxVol;     $('valSfx').textContent=config.sfxVol;
  document.querySelectorAll('[data-group="shake"]').forEach(b=>b.classList.toggle('on',b.dataset.val==='1'?config.screenShake:!config.screenShake));
  document.querySelectorAll('[data-group="par"]').forEach(b=>b.classList.toggle('on',b.dataset.val===config.particles));
}
['slMaster','slMusic','slSfx'].forEach(id=>{
  $(id).addEventListener('input',e=>{
    const map={slMaster:'masterVol',slMusic:'musicVol',slSfx:'sfxVol'};
    const valId={slMaster:'valMaster',slMusic:'valMusic',slSfx:'valSfx'};
    config[map[id]]=+e.target.value;
    $(valId[id]).textContent=e.target.value;
    applyVolumes();saveCfg();
  });
});
document.querySelectorAll('.tgl').forEach(b=>b.addEventListener('click',()=>{
  const g=b.dataset.group,v=b.dataset.val;
  if(g==='shake'){config.screenShake=v==='1';}
  if(g==='par'){config.particles=v;}
  document.querySelectorAll(`[data-group="${g}"]`).forEach(x=>x.classList.remove('on'));
  b.classList.add('on');saveCfg();
}));
$('btnFullscreen').addEventListener('click',()=>{
  if(!document.fullscreenElement)document.documentElement.requestFullscreen?.();
  else document.exitFullscreen?.();
});
$('btnResetSave').addEventListener('click',()=>{
  if(confirm('Reset ALL records, amber, and settings? This cannot be undone.')){
    saveData={amber:0,bestScore:0,bestTime:0,classBest:{},totalRuns:0,totalKills:0};
    writeSave();DOM.menuAmber.textContent='';
    alert('Data reset. See you in the swarm.');
  }
});

// ─── Volume HUD in-game ───────────────────────────────────────────
function updateVolHud(){
  DOM.volHud.textContent=`♪ MUSIC: ${config.musicVol}  SFX: ${config.sfxVol}  [M] TOGGLE`;
}
updateVolHud();

// ─── Tab System (HTP) ─────────────────────────────────────────────
document.querySelectorAll('.htab').forEach(tab=>{
  tab.addEventListener('click',()=>{
    const id=tab.dataset.tab;
    document.querySelectorAll('.htab').forEach(t=>t.classList.remove('on'));
    document.querySelectorAll('.htab-panel').forEach(p=>p.classList.remove('on'));
    tab.classList.add('on');
    const panel=document.getElementById(id);if(panel)panel.classList.add('on');
  });
});

// ─── Touch Joystick ───────────────────────────────────────────────
const joyArea=$('joyArea'),joyKnob=$('joyKnob');
let joyOriX=0,joyOriY=0,joyDown=false;
joyArea.addEventListener('touchstart',e=>{if(gameState!=='playing')return;e.preventDefault();const t=e.touches[0];joyDown=true;joyOriX=t.clientX;joyOriY=t.clientY;},{passive:false});
joyArea.addEventListener('touchmove',e=>{if(!joyDown)return;e.preventDefault();const t=e.touches[0],dx=t.clientX-joyOriX,dy=t.clientY-joyOriY,mag=Math.sqrt(dx*dx+dy*dy)||1,mr=45,cm=Math.min(mag,mr);joyX=(dx/mag)*(cm/mr);joyY=(dy/mag)*(cm/mr);joyKnob.style.left=39+joyX*mr+'px';joyKnob.style.top=39+joyY*mr+'px';},{passive:false});
['touchend','touchcancel'].forEach(ev=>joyArea.addEventListener(ev,()=>{joyDown=false;joyX=0;joyY=0;joyKnob.style.left='39px';joyKnob.style.top='39px';}));
$('abilBtn').addEventListener('touchstart',e=>{e.preventDefault();initAudio();resumeAX();if(gameState==='playing')useAbility();},{passive:false});

// ─── Keyboard Input ───────────────────────────────────────────────
addEventListener('keydown',e=>{
  keys[e.code]=true;
  if(e.code==='Space'){e.preventDefault();initAudio();resumeAX();if(gameState==='playing')useAbility();}
  if(e.code==='Escape'){e.preventDefault();if(gameState==='playing'||gameState==='paused')togglePause();}
  if(e.code==='KeyM'&&gameState==='playing'){toggleMusic();updateVolHud();}
  if((e.code==='BracketLeft')&&gameState==='playing'){config.sfxVol=Math.max(0,config.sfxVol-10);$('slSfx').value=config.sfxVol;applyVolumes();saveCfg();updateVolHud();}
  if((e.code==='BracketRight')&&gameState==='playing'){config.sfxVol=Math.min(100,config.sfxVol+10);$('slSfx').value=config.sfxVol;applyVolumes();saveCfg();updateVolHud();}
});
addEventListener('keyup',e=>keys[e.code]=false);

// ─── Button Bindings ──────────────────────────────────────────────
$('btnPlay').onclick=()=>{initAudio();resumeAX();setupClassSelect();showScreen('sClass');gameState='classSelect';};
$('btnHtp').onclick=()=>{buildHTP();showScreen('sHtp');gameState='htp';};
$('btnSettings').onclick=()=>{applySettingsUI();showScreen('sSettings');gameState='settings';};
$('btnRecords').onclick=()=>{buildRecords();showScreen('sRecords');gameState='records';};
$('btnBackMenu2').onclick=$('btnBackHtp').onclick=$('btnBackSettings').onclick=$('btnBackRecords').onclick=()=>{showScreen('sMenu');gameState='menu';startMenuBg();};
$('btnResume').onclick=()=>togglePause();
$('btnPSettings').onclick=()=>{if(gameState==='paused'){applySettingsUI();showScreen('sSettings');gameState='settings';}};
$('btnAbort').onclick=()=>{
  gameState='menu';frozen=false;SYNERGIES.forEach(s=>s.active=false);
  if(rafId){cancelAnimationFrame(rafId);rafId=0;}
  stopMusic();
  DOM.hud.style.display='none';DOM.abilInd.style.display='none';DOM.volHud.style.display='none';
  showScreen('sMenu');startMenuBg();
};
$('btnRetry').onclick=()=>{setupClassSelect();showScreen('sClass');gameState='classSelect';};
$('btnGoMenu').onclick=()=>{
  DOM.hud.style.display='none';DOM.abilInd.style.display='none';DOM.volHud.style.display='none';
  showScreen('sMenu');gameState='menu';startMenuBg();
};

// ─── Init Settings ────────────────────────────────────────────────
applySettingsUI();
DOM.menuAmber.textContent=saveData.amber>0?`⬡ AMBER: ${saveData.amber}`:'';
</script>
</body>
</html>
