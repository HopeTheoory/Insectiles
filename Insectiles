      </div>
      <div class="htp-stat-bars">
        <div class="stat-bar-row">HP${bar(c.statHp,5)}</div>
        <div class="stat-bar-row">ATK SPD${bar(c.statAs,5)}</div>
        <div class="stat-bar-row">DAMAGE${bar(c.statDmg,5)}</div>
        <div class="stat-bar-row">SPEED${bar(c.statSpd,5)}</div>
