// ─── Audio Engine (Web Audio API — zero external files) ───────────
let AX=null, masterGain=null, musicGain=null, sfxGain=null;
let musicOsc=null, musicDrone=null, musicPlaying=false;

function initAudio(){
  if(AX)return;
  try{
    AX=new(window.AudioContext||window.webkitAudioContext)();
    masterGain=AX.createGain(); const comp=AX.createDynamicsCompressor(); comp.threshold.setValueAtTime(-24, AX.currentTime); comp.knee.setValueAtTime(40, AX.currentTime); comp.ratio.setValueAtTime(12, AX.currentTime); comp.attack.setValueAtTime(0, AX.currentTime); comp.release.setValueAtTime(0.25, AX.currentTime); masterGain.connect(comp); comp.connect(AX.destination);
    musicGain=AX.createGain();  musicGain.connect(masterGain);
    sfxGain=AX.createGain();    sfxGain.connect(masterGain);
    applyVolumes();
  }catch(e){AX=null;}
}
function applyVolumes(){
  if(!AX)return;
  masterGain.gain.setTargetAtTime(config.masterVol/100,.0,.05);
  musicGain.gain.setTargetAtTime(config.musicVol/100,.0,.05);
  sfxGain.gain.setTargetAtTime(config.sfxVol/100,.0,.05);
}
function resumeAX(){if(AX&&AX.state==='suspended')AX.resume();}

// SFX generator
function sfx(type){
  if(!AX||config.sfxVol===0||config.masterVol===0)return;
  const t=AX.currentTime;
  const g=AX.createGain(); g.connect(sfxGain);
  switch(type){
    case'hit':{
      const buf=AX.createBuffer(1,AX.sampleRate*.05,AX.sampleRate);
      const d=buf.getChannelData(0);for(let i=0;i<d.length;i++)d[i]=(random()*2-1)*.6;
      const s=AX.createBufferSource();s.buffer=buf;s.connect(g);
      g.gain.setValueAtTime(.35,t);g.gain.exponentialRampToValueAtTime(.001,t+.05);
      s.start(t);break;
    }
    case'shoot':{
      const o=AX.createOscillator();o.type='square';o.frequency.setValueAtTime(800,t);
      o.frequency.exponentialRampToValueAtTime(200,t+.08);o.connect(g);
      g.gain.setValueAtTime(.15,t);g.gain.exponentialRampToValueAtTime(.001,t+.08);
      o.start(t);o.stop(t+.08);setTimeout(()=>o.disconnect(), 150);break;
    }
    case'gem':{
      const o=AX.createOscillator();o.type='sine';o.frequency.setValueAtTime(880,t);
      o.frequency.exponentialRampToValueAtTime(1320,t+.08);o.connect(g);
      g.gain.setValueAtTime(.18,t);g.gain.exponentialRampToValueAtTime(.001,t+.1);
      o.start(t);o.stop(t+.1);setTimeout(()=>o.disconnect(), 150);break;
    }
    case'levelup':{
      [523,659,784,1047].forEach((f,i)=>{
        const o=AX.createOscillator();o.type='sine';o.frequency.setValueAtTime(f,t+i*.06);
        o.connect(g);g.gain.setValueAtTime(.22,t+i*.06);
        g.gain.exponentialRampToValueAtTime(.001,t+i*.06+.18);
        o.start(t+i*.06);o.stop(t+i*.06+.18);setTimeout(()=>o.disconnect(), 250);
      });break;
    }
    case'ability':{
      const o=AX.createOscillator();o.type='sawtooth';o.frequency.setValueAtTime(200,t);
      o.frequency.exponentialRampToValueAtTime(600,t+.12);o.connect(g);
      const f=AX.createBiquadFilter();f.type='bandpass';f.frequency.value=400;
      o.disconnect();o.connect(f);f.connect(g);
      g.gain.setValueAtTime(.25,t);g.gain.exponentialRampToValueAtTime(.001,t+.15);
      o.start(t);o.stop(t+.15);setTimeout(()=>o.disconnect(), 200);break;
    }
    case'hurt':{
      const o=AX.createOscillator();o.type='sawtooth';o.frequency.setValueAtTime(120,t);
      o.frequency.exponentialRampToValueAtTime(55,t+.12);o.connect(g);
      g.gain.setValueAtTime(.3,t);g.gain.exponentialRampToValueAtTime(.001,t+.12);
      o.start(t);o.stop(t+.12);setTimeout(()=>o.disconnect(), 200);break;
    }
    case'gameover':{
      [440,330,220,110].forEach((f,i)=>{
        const o=AX.createOscillator();o.type='sawtooth';o.frequency.setValueAtTime(f,t+i*.22);
        o.connect(g);g.gain.setValueAtTime(.2,t+i*.22);
        g.gain.exponentialRampToValueAtTime(.001,t+i*.22+.3);
        o.start(t+i*.22);o.stop(t+i*.22+.3);setTimeout(()=>o.disconnect(), 400);
      });break;
    }
    case'boss':{
      const o=AX.createOscillator();o.type='sawtooth';o.frequency.setValueAtTime(55,t);
      o.connect(g);g.gain.setValueAtTime(.45,t);g.gain.exponentialRampToValueAtTime(.001,t+.8);
      o.start(t);o.stop(t+.8);setTimeout(()=>o.disconnect(), 900);
      const o2=AX.createOscillator();o2.type='square';o2.frequency.setValueAtTime(880,t);
      o2.frequency.exponentialRampToValueAtTime(55,t+.5);o2.connect(g);o2.start(t);o2.stop(t+.5);setTimeout(()=>o2.disconnect(), 600);break;
    }
    case'synergy':{
      [261,329,392,523,659].forEach((f,i)=>{
        const o=AX.createOscillator();o.type='sine';o.frequency.setValueAtTime(f,t+i*.07);
        o.connect(g);g.gain.setValueAtTime(.28,t+i*.07);
        g.gain.exponentialRampToValueAtTime(.001,t+i*.07+.25);
        o.start(t+i*.07);o.stop(t+i*.07+.25);setTimeout(()=>o.disconnect(), 350);
      });break;
    }
    case'streak':{
      const o=AX.createOscillator();o.type='sine';o.frequency.setValueAtTime(660,t);
      o.frequency.exponentialRampToValueAtTime(1320,t+.1);o.connect(g);
      g.gain.setValueAtTime(.2,t);g.gain.exponentialRampToValueAtTime(.001,t+.12);
      o.start(t);o.stop(t+.12);setTimeout(()=>o.disconnect(), 200);break;
    }
  }
}

// Procedural ambient music
function startMusic(){
  if(!AX||musicPlaying)return;
  musicPlaying=true;
  const t=AX.currentTime;
  // Low drone
  musicDrone=AX.createOscillator(); musicDrone.type='sine';
  musicDrone.frequency.setValueAtTime(55,t);
  const dg=AX.createGain(); dg.gain.setValueAtTime(.06,t);
  musicDrone.connect(dg); dg.connect(musicGain);
  musicDrone.start(t);
  // Pulsing pad
  function schedPad(when){
    if(!musicPlaying)return;
    const notes=[110,138,165,110,138,165,184];
    notes.forEach((f,i)=>{
      const o=AX.createOscillator(); o.type='triangle';
      o.frequency.setValueAtTime(f,when+i*.45);
      const g2=AX.createGain(); g2.gain.setValueAtTime(0,when+i*.45);
      g2.gain.linearRampToValueAtTime(.04,when+i*.45+.12);
      g2.gain.linearRampToValueAtTime(0,when+i*.45+.38);
      o.connect(g2); g2.connect(musicGain);
      o.start(when+i*.45); o.stop(when+i*.45+.4); setTimeout(()=>o.disconnect(), (when+i*.45+.4 - AX.currentTime)*1000 + 100);
    });
    if(musicPlaying) setTimeout(()=>schedPad(AX.currentTime+.1),notes.length*450+100);
  }
  schedPad(t+.5);
}
function stopMusic(){
  if(!musicPlaying)return;
  musicPlaying=false;
  try{if(musicDrone){musicDrone.stop();musicDrone=null;}}catch{}
}
function toggleMusic(){
  if(musicPlaying)stopMusic();
  else{if(AX&&AX.state==='suspended')AX.resume();startMusic();}
}

