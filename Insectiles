    synPanel.dataset.built='1';
    SYNERGIES.forEach(syn=>{
      const d=document.createElement('div');d.className='syn-card';d.style.borderColor=syn.col+'66';d.style.background=syn.col+'08';
      const reqs=Object.entries(syn.req).map(([id,n])=>{const u=UPGRADES.find(u=>u.id===id);return `${u?u.name:id} Lv.${n}`;}).join(' + ');
      d.innerHTML=`<div style="font-family:var(--font-game);font-size:.78rem;font-weight:700;color:${syn.col};letter-spacing:3px">${syn.icon} ${syn.name}</div>
