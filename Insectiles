function mkEnemy(tk){
  const d=ETYPES[tk],pos=spawnPos(),hs=1+waveNum*.11,ss=1+waveNum*.03;
  liveEnemyCount++;
  return{x:pos.x,y:pos.y,type:tk,col:d.col,r:d.r,
    hp:d.hp*hs,maxHp:d.hp*hs,spd:d.spd*ss,baseSpd:d.spd*ss,
    dmg:d.dmg,xp:d.xp,sc:d.sc,elite:d.elite,ranged:d.ranged,
    sTimer:0,sInt:2,healT:0,healInt:3,poisonT:0,poisonDps:0,slowT:0,flashT:0,vx:0,vy:0,dead:false};
}
function mkBoss(){
  const pos=spawnPos(),sc=1+waveNum*.12;
  liveEnemyCount++;
  return{x:pos.x,y:pos.y,type:'boss',col:'#ff2200',r:44,isBoss:true,
    hp:800*sc,maxHp:800*sc,spd:52,baseSpd:52,dmg:22,xp:120,sc:500,
    elite:true,ranged:true,sTimer:0,sInt:.9,
    poisonT:0,poisonDps:0,slowT:0,flashT:0,vx:0,vy:0,dead:false};
}
function mkProj(x,y,tx,ty,spd,dmg,col,r,owner,poison){
  const dx=tx-x,dy=ty-y,dd=Math.sqrt(dx*dx+dy*dy)||1;
  return{x,y,vx:(dx/dd)*spd,vy:(dy/dd)*spd,dmg,col,r,owner,poison:poison||0,life:3,trail:[],dead:false};
}

// Particle spawn with quality scaling
function spawnParts(x,y,col,n,spd,life,sz){
  const cnt=Math.min(Math.floor(n*PAR_MULT[config.particles]),380-parts.length);
  for(let i=0;i<cnt;i++){
    const a=random()*TAU,s=spd*(random()*.7+.3);
    parts.push({x,y,vx:Math.cos(a)*s,vy:Math.sin(a)*s,col,life:life*(random()*.5+.5),maxLife:life,sz:sz*(random()*.8+.5)});
  }
}
function spawnDmg(x,y,val,col){
  if(dmgNums.length>=65)return;
  dmgNums.push({x,y:y-18,vy:-58,val:Math.ceil(val),col:col||'#fff',life:1.2,maxLife:1.2,big:val>=18});
}

function waveType(){
  const t=gTime,r=random();
  if(t<12)return r<.65?'ant':'beetle';
  if(t<28)return r<.45?'ant':r<.75?'beetle':'soldier';
  if(t<55){if(r<.3)return'ant';if(r<.55)return'beetle';if(r<.75)return'soldier';if(r<.9)return'hornet';return'spitter';}
  if(r<.18)return'ant';if(r<.38)return'beetle';if(r<.54)return'soldier';if(r<.68)return'hornet';if(r<.83)return'spitter';return'shaman';
}

// ─── Combat ───────────────────────────────────────────────────────
function dealDmg(e,dmg){
  if(e.dead||e.hp<=0)return;
  e.hp-=dmg; e.flashT=.12;
  spawnDmg(e.x,e.y,dmg);
  const now=performance.now();
  if(now-sfxLastHit>90){sfxLastHit=now;sfx('hit');}
  if(e.hp<=0)killEnemy(e);
}
function killEnemy(e){
  if(e.dead)return;
  e.dead=true; e.hp=0; liveEnemyCount=Math.max(0,liveEnemyCount-1);
  gems.push({x:e.x+randomRange(-12,12),y:e.y+randomRange(-12,12),val:e.xp,
    col:(e.elite||e.isBoss)?'#ffd700':'#00ff88',r:(e.elite||e.isBoss)?7:5,bob:random()*TAU});
  score+=(e.isBoss?e.sc:e.sc*waveNum); kills++;
  killStreak++; streakT=4.5;
  if(killStreak===5||killStreak===10||killStreak===20)sfx('streak');
  const pn=e.isBoss?28:e.elite?14:7,ps=e.isBoss?180:115,pl=.55,pr=e.isBoss?7:e.elite?5:3;
  spawnParts(e.x,e.y,e.col,pn,ps,pl,pr);
  if(e.isBoss){bossActive=false;showBanner('BOSS SLAIN!','#ff2200',2);}
  if(player.syns.has('venomLord')){
    const vr=e.isBoss?165:95,vr2=vr*vr;
    for(const e2 of enemies)if(!e2.dead&&e2!==e&&squareDistance(e,e2)<vr2){e2.poisonT=4;e2.poisonDps=player.eDmg*.8;}
    spawnParts(e.x,e.y,'#00ff88',18,75,1,.7);
  }
  if(player.syns.has('apexPred')&&(e.elite||e.isBoss)){
    const heal=player.maxHp*.15;player.hp=Math.min(player.maxHp,player.hp+heal);spawnDmg(player.x,player.y-28,heal,'#00ff88');
  }
}
function hurtPlayer(dmg){
  if(player.invuln>0)return;
  let d=player.syns.has('ironHide')?dmg*.45:dmg;
  player.hp-=d; spawnDmg(player.x,player.y-28,d,'#ff4444');
  sfx('hurt');
  if(config.screenShake){shake.t=.18;shake.i=7;}
  if(player.hp<=0){
    if(player.S.revive&&!player.S.reviveUsed){
      player.S.reviveUsed=true;player.hp=player.maxHp*.5;player.invuln=3.5;
      spawnParts(player.x,player.y,'#fff',28,180,1.2,9);
    }else endGame();
  }
}
function nearest(from,maxR){
  let best=null,bd=maxR*maxR;
  for(const e of enemies){if(!e.dead){const dd=squareDistance(from,e);if(dd<bd){bd=dd;best=e;}}}
  return best;
}

// ─── Ability ──────────────────────────────────────────────────────
function useAbility(){
  if(player.abilCd>0)return;
  player.abilCd=player.eCd; sfx('ability');
  switch(player.cls){
    case'mantis':{const t=nearest(player,220);if(t){const d=player.eDmg*5.5;dealDmg(t,d);spawnParts(t.x,t.y,'#00ff88',18,180,.45,6);spawnDmg(t.x,t.y-30,d,'#00ff88');abilFx={type:'lightning',x:player.x,y:player.y,tx:t.x,ty:t.y,life:.35,maxLife:.35};}break;}
    case'scarab': player.invuln=3.5;spawnParts(player.x,player.y,'#ffd700',26,140,.55,8);abilFx={type:'shield',x:player.x,y:player.y,r:65,life:3.5,maxLife:3.5};break;
    case'widow':  for(const e of enemies)if(!e.dead&&distance(player,e)<185){dealDmg(e,player.eDmg*2.2);e.poisonT=5;e.poisonDps=player.eDmg*.55+player.S.poisonDps;}spawnParts(player.x,player.y,'#ff0066',36,115,.75,8);abilFx={type:'cloud',x:player.x,y:player.y,r:185,life:.55,maxLife:.55};break;
    case'wasp':   for(let i=0;i<8;i++){const a=(i/8)*TAU;projs.push({x:player.x,y:player.y,vx:Math.cos(a)*420,vy:Math.sin(a)*420,dmg:player.eDmg*2.2,col:'#ffaa00',r:6,owner:'player',poison:player.S.poisonDps,life:1.6,trail:[],dead:false});}spawnParts(player.x,player.y,'#ffaa00',16,185,.38,6);break;
    case'moth':   for(const e of enemies)if(!e.dead&&distance(player,e)<310&&e.slowT<=0){e.spd=e.baseSpd*.28;e.slowT=4;}spawnParts(player.x,player.y,'#aa88ff',44,140,.95,9);abilFx={type:'dust',x:player.x,y:player.y,r:310,life:.6,maxLife:.6};break;
  }
}
function doAttack(t){
  const cls=player.classDef,d=player.eDmg,h=1+player.S.multiStrike;
  const now=performance.now();
  if(cls.ranged){
    for(let i=0;i<h;i++){
      const sp=(i-(h-1)/2)*.14,ang=Math.atan2(t.y-player.y,t.x-player.x)+sp;
      projs.push({x:player.x,y:player.y,vx:Math.cos(ang)*455,vy:Math.sin(ang)*455,
        dmg:d,col:cls.projCol,r:cls.projR,owner:'player',poison:player.S.poisonDps,life:cls.range/455,trail:[],dead:false});
    }
    if(now-sfxLastShoot>100){sfxLastShoot=now;sfx('shoot');}
  }else{
    dealDmg(t,d*h);spawnParts(t.x,t.y,player.color,5,90,.25,4);
    if(player.S.lifesteal>0)player.hp=Math.min(player.maxHp,player.hp+d*h*player.S.lifesteal);
  }
  spawnParts(player.x+Math.cos(player.angle)*38,player.y+Math.sin(player.angle)*38,player.color,3,70,.18,4);
}

// ─── Upgrades ─────────────────────────────────────────────────────
const upgLv=id=>player.upgLv[id]||0;
function applyUpg(id){
  const u=UPGRADES.find(u=>u.id===id);if(!u||upgLv(id)>=u.maxLv)return;
  player.upgLv[id]=(player.upgLv[id]||0)+1;u.apply(player);checkSyns();
}
function checkSyns(){
  for(const syn of SYNERGIES){
    if(syn.active)continue;
    if(Object.entries(syn.req).every(([id,n])=>upgLv(id)>=n)){
      syn.active=true;player.syns.add(syn.id);synQueue.push(syn);sfx('synergy');
    }
  }
}
function pick3(){
  const pool=UPGRADES.filter(u=>upgLv(u.id)<u.maxLv),res=[];
  while(res.length<3&&pool.length>0){const i=Math.floor(random()*pool.length);res.push(pool.splice(i,1)[0]);}
  return res;
}

// ─── Main Update ──────────────────────────────────────────────────
function update(dt){
  if(gameState!=='playing'||frozen)return;
  gTime+=dt; waveT+=dt;
  if(waveT>=30){
    waveNum++;waveT=0;spawnI=Math.max(.28,spawnI-.09);
    if(waveNum%5===0&&!bossActive)spawnBoss();
    else showBanner(`WAVE ${waveNum}`,'#ffaa44',1.5);
  }
  if(shake.t>0){shake.t=Math.max(0,shake.t-dt);shake.x=(random()-.5)*shake.i;shake.y=(random()-.5)*shake.i;}
  else{shake.x=0;shake.y=0;}
  if(streakT>0){streakT-=dt;if(streakT<=0){killStreak=0;streakT=0;}}
  if(synQueue.length>0&&synT<=0){showSyn(synQueue[0]);synT=2.8;}
  if(synT>0){synT-=dt;if(synT<=0){synQueue.shift();DOM.synNotif.style.display='none';synT=0;}}
  updatePlayer(dt);updateEnemies(dt);updateProjectiles(dt);updateGems(dt);updateParticles(dt);updateDamageNumbers(dt);
  spawnT+=dt;
  const maxE=25+waveNum*14;
  if(spawnT>=spawnI&&liveEnemyCount<maxE){
    spawnT=0;enemies.push(mkEnemy(waveType()));
    if(gTime>18&&random()<.32)enemies.push(mkEnemy(waveType()));
    if(gTime>45&&random()<.18)enemies.push(mkEnemy(waveType()));
  }
  if(enemies.length>260)enemies=enemies.filter(e=>!e.dead);
  if(projs.length>200)projs=projs.filter(p=>!p.dead);
  if(abilFx){abilFx.life-=dt;if(abilFx.life<=0)abilFx=null;}
  updateHUD();
}

let joyX=0,joyY=0;
function updatePlayer(dt){
  let mx=0,my=0;
  if(keys['KeyW']||keys['ArrowUp'])my-=1;
  if(keys['KeyS']||keys['ArrowDown'])my+=1;
  if(keys['KeyA']||keys['ArrowLeft'])mx-=1;
  if(keys['KeyD']||keys['ArrowRight'])mx+=1;
  if(joyX!==0||joyY!==0){mx=joyX;my=joyY;}
  if(mx&&my){mx*=.707;my*=.707;}
  player.x=clamp(player.x+mx*player.eSpd*dt,20,WORLD_WIDTH-20);
  player.y=clamp(player.y+my*player.eSpd*dt,20,WORLD_HEIGHT-20);
  if(mx||my)player.angle=Math.atan2(my,mx);
  cam.x=player.x;cam.y=player.y;
  player.trail.unshift({x:player.x,y:player.y});if(player.trail.length>9)player.trail.pop();
  player.invuln=Math.max(0,player.invuln-dt);
  player.abilCd=Math.max(0,player.abilCd-dt);
  player.atTimer=Math.max(0,player.atTimer-dt);
  if(player.atTimer<=0){const t=nearest(player,player.classDef.range);if(t){player.atTimer=1/player.eAS;doAttack(t);}}
  if(player.syns.has('bladeStorm')){
    const ba=gTime*3;
    for(let i=0;i<6;i++){
      const a=ba+(i/6)*TAU,bx=player.x+Math.cos(a)*68,by=player.y+Math.sin(a)*68;
      for(const e of enemies)if(!e.dead&&squareDistance({x:bx,y:by},e)<400)dealDmg(e,player.eDmg*.55*dt*10);
    }
  }
}

function updateEnemies(dt){
  for(const e of enemies){
    if(e.dead)continue;
    const dx=player.x-e.x,dy=player.y-e.y,dd=Math.sqrt(dx*dx+dy*dy)||1;
    if(dd>(e.ranged?240:0)){e.vx=(dx/dd)*e.spd;e.vy=(dy/dd)*e.spd;}else{e.vx*=.88;e.vy*=.88;}
    // Lightweight separation (skip for fodder at high counts)
    if(e.elite||liveEnemyCount<60){
      for(const e2 of enemies){
        if(e2===e||e2.dead)continue;
        const sdx=e.x-e2.x,sdy=e.y-e2.y,sdd=sdx*sdx+sdy*sdy;
        const md=(e.r+e2.r)*1.1;
        if(sdd<md*md&&sdd>.001){const sd=Math.sqrt(sdd),push=.35*(md-sd)/sd;e.vx+=sdx*push;e.vy+=sdy*push;}
      }
    }
    e.x=clamp(e.x+e.vx*dt,0,WORLD_WIDTH);e.y=clamp(e.y+e.vy*dt,0,WORLD_HEIGHT);
    e.flashT=Math.max(0,e.flashT-dt);
    if(e.slowT>0){e.slowT-=dt;if(e.slowT<=0){e.spd=e.baseSpd;e.slowT=0;}}
    if(dd<e.r+PLAYER_RADIUS&&player.invuln<=0){
      if(player.S.thorns>0)dealDmg(e,e.dmg*dt*1.4*player.S.thorns);
      hurtPlayer(e.dmg*dt*1.4);
    }
    if(e.ranged){
      e.sTimer+=dt;const shootR=e.isBoss?600:420;
      if(e.sTimer>=e.sInt&&dd<shootR){
        e.sTimer=0;
        projs.push(mkProj(e.x,e.y,player.x,player.y,e.isBoss?275:195,e.dmg,e.isBoss?'#ff4400':'#00cc44',e.isBoss?10:6,'enemy',0));
        if(e.isBoss){for(const sp of[-.22,.22]){const ang=Math.atan2(player.y-e.y,player.x-e.x)+sp;projs.push({x:e.x,y:e.y,vx:Math.cos(ang)*255,vy:Math.sin(ang)*255,dmg:e.dmg*.7,col:'#ff4400',r:8,owner:'enemy',poison:0,life:3,trail:[],dead:false});}}
      }
    }
    if(e.type==='shaman'){e.healT+=dt;if(e.healT>=e.healInt){e.healT=0;for(const e2 of enemies)if(!e2.dead&&e2!==e&&distance(e,e2)<148){e2.hp=Math.min(e2.maxHp,e2.hp+e2.maxHp*.1);spawnParts(e2.x,e2.y,'#cc00ff',5,55,.38,4);}}}
    if(e.poisonT>0){e.poisonT-=dt;e.hp-=e.poisonDps*dt;if(random()<.07)spawnParts(e.x,e.y,'#00ff44',1,25,.28,3);if(e.hp<=0)killEnemy(e);}
  }
}

function updateProjectiles(dt){
  for(const p of projs){
    if(p.dead)continue;
    p.trail.unshift({x:p.x,y:p.y});if(p.trail.length>5)p.trail.pop();
    p.x+=p.vx*dt;p.y+=p.vy*dt;p.life-=dt;if(p.life<=0){p.dead=true;continue;}
    if(p.owner==='player'){
      for(const e of enemies){
        if(!e.dead&&squareDistance(p,e)<(p.r+e.r)*(p.r+e.r)){
          dealDmg(e,p.dmg);if(p.poison>0){e.poisonT=3;e.poisonDps=p.poison;}
          if(player.S.lifesteal>0)player.hp=Math.min(player.maxHp,player.hp+p.dmg*player.S.lifesteal);
          spawnParts(p.x,p.y,p.col,5,75,.28,3);p.dead=true;break;
        }
      }
    }else if(squareDistance(p,player)<(p.r+PLAYER_RADIUS)*(p.r+PLAYER_RADIUS)){hurtPlayer(p.dmg);spawnParts(p.x,p.y,'#ff4444',5,75,.28,4);p.dead=true;}
  }
}

function updateGems(dt){
  for(let i=gems.length-1;i>=0;i--){
    const g=gems[i];g.bob+=dt*2;
    if(squareDistance(g,player)<COLLECTIBLE_RADIUS*COLLECTIBLE_RADIUS){const dx=player.x-g.x,dy=player.y-g.y,d=Math.sqrt(dx*dx+dy*dy)||1;g.x+=(dx/d)*380*dt;g.y+=(dy/d)*380*dt;}
    if(squareDistance(g,player)<(PLAYER_RADIUS+g.r)*(PLAYER_RADIUS+g.r)){
      player.xp+=g.val;gems.splice(i,1);
      const now=performance.now();
      if(now-sfxLastGem>55){sfxLastGem=now;sfx('gem');}
      spawnParts(player.x,player.y,g.col,2,55,.28,3);
      let leveled=false;
      while(player.xp>=player.xpN&&player.lv<XP_T.length-1){player.xp-=player.xpN;player.lv++;player.xpN=XP_T[player.lv]||(player.xpN*1.35|0);lvlPending++;leveled=true;}
      if(leveled&&gameState==='playing'){sfx('levelup');showLvlUp();}
    }
  }
}

function updateParticles(dt){for(let i=parts.length-1;i>=0;i--){const p=parts[i];p.x+=p.vx*dt;p.y+=p.vy*dt;p.vx*=.93;p.vy*=.93;p.life-=dt;if(p.life<=0)parts.splice(i,1);}}
function updateDamageNumbers(dt){for(let i=dmgNums.length-1;i>=0;i--){const d=dmgNums[i];d.y+=d.vy*dt;d.vy+=30*dt;d.life-=dt;if(d.life<=0)dmgNums.splice(i,1);}}

function spawnBoss(){
  bossActive=true;enemies.push(mkBoss());
  sfx('boss');showBanner('⚠  BOSS  INCOMING  ⚠','#ff2200',2.5);
}

// ─── HUD (dirty-check) ────────────────────────────────────────────
function updateHUD(){
  const hp=Math.max(0,player.hp/player.maxHp*100);
  if(Math.abs(hp-_lHp)>.4){DOM.hpFill.style.width=hp.toFixed(1)+'%';DOM.hpVal.textContent=`${Math.ceil(player.hp)}/${player.maxHp}`;_lHp=hp;}
  const xp=Math.min(100,player.xp/player.xpN*100);
  if(Math.abs(xp-_lXp)>.4){DOM.xpFill.style.width=xp.toFixed(1)+'%';DOM.xpVal.textContent=`Lv.${player.lv}`;_lXp=xp;}
  if(score!==_lSc){
    const m=Math.floor(gTime/60),s=Math.floor(gTime%60);
    DOM.hudTimer.textContent=`${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
    DOM.hudWave.textContent=bossActive?`⚠ BOSS WAVE ${waveNum}`:`WAVE ${waveNum}`;
    DOM.hudScore.textContent=`SCORE: ${score.toLocaleString()}`;
    if(saveData.bestScore>0)DOM.hudBest.textContent=`BEST: ${saveData.bestScore.toLocaleString()}`;
    _lSc=score;
  }
  if(killStreak!==_lStr){
    if(killStreak>=5){const sc=killStreak>=20?'#ff2200':killStreak>=10?'#ffaa00':'#ffd700';DOM.hudStreak.style.color=sc;DOM.hudStreak.textContent=`${killStreak}x STREAK`;}
    else DOM.hudStreak.textContent='';
    _lStr=killStreak;
  }
  if(player.syns.size!==_lSyn){DOM.hudSyns.innerHTML=SYNERGIES.filter(s=>s.active).map(s=>`<span style="color:${s.col}">${s.icon} ${s.name}</span>`).join('<br>');_lSyn=player.syns.size;}
  const rdy=player.abilCd<=0,cdStr=player.abilCd.toFixed(1);
  if((rdy?0:1)!==(_lCd>0?1:0)||(!rdy&&cdStr!==String(_lCd))){
    DOM.abilInd.textContent=rdy?`[SPACE] ${player.classDef.abil} — READY`:`[SPACE] ${player.classDef.abil} — ${cdStr}s`;
    DOM.abilInd.style.color=rdy?'#88ffff':'#334455';
    DOM.abilInd.style.borderColor=rdy?'rgba(136,255,255,.45)':'rgba(50,80,100,.35)';
    DOM.abilInd.style.background=rdy?'rgba(136,255,255,.07)':'transparent';
    _lCd=rdy?0:parseFloat(cdStr);
  }
}

// ─── Banners & Notifications ──────────────────────────────────────
let bannerTO=null;
function showBanner(text,col,dur=1.8){
  if(bannerTO)clearTimeout(bannerTO);
  DOM.waveBanner.innerHTML=`<div style="font-family:'Orbitron',monospace;font-weight:900;font-size:clamp(1.8rem,4vw,3rem);color:${col};text-shadow:0 0 30px ${col}88;letter-spacing:6px">${text}</div>`;
  DOM.waveBanner.style.display='block';
  DOM.waveBanner.style.animation='none';DOM.waveBanner.offsetHeight;
  DOM.waveBanner.style.animation=`waveIn ${dur}s ease forwards`;
  bannerTO=setTimeout(()=>DOM.waveBanner.style.display='none',dur*1000+200);
}
function showSyn(syn){
  DOM.synNotif.style.border=`3px solid ${syn.col}`;
  DOM.synNotif.innerHTML=`<div style="font-size:2rem;margin-bottom:6px">${syn.icon}</div>
    <div style="font-family:'Orbitron',monospace;font-size:.82rem;font-weight:900;letter-spacing:4px;color:${syn.col};text-shadow:0 0 16px ${syn.col}">SYNERGY UNLOCKED</div>
    <div style="font-family:'Orbitron',monospace;font-size:1rem;color:${syn.col};margin-top:5px;letter-spacing:3px">${syn.name}</div>
    <div style="font-family:'Share Tech Mono',monospace;font-size:.7rem;color:#888;margin-top:7px">${syn.desc}</div>`;
  DOM.synNotif.style.display='block';
  DOM.synNotif.style.animation='none';DOM.synNotif.offsetHeight;
  DOM.synNotif.style.animation='synPop .42s ease forwards';
}

// ─── Level Up ─────────────────────────────────────────────────────
function showLvlUp(){
  frozen=true;gameState='levelup';
  const ups=pick3();
  DOM.luSub.textContent=`LEVEL ${player.lv} — CHOOSE AN UPGRADE`;
  DOM.upgCards.innerHTML='';
  if(ups.length===0){score+=500*player.lv;lvlPending=0;frozen=false;gameState='playing';return;}
  ups.forEach(u=>{
    const lv=upgLv(u.id);
    const card=document.createElement('div');card.className='ucrd';
    card.innerHTML=`<div class="uicon">${u.icon}</div><div class="uname">${u.name}</div><div class="udesc">${u.desc(lv+1)}</div><div class="ulvl">Lv ${lv+1}/${u.maxLv}</div>`;
    card.onclick=()=>{
      applyUpg(u.id);lvlPending--;
      showScreen(null);
      if(lvlPending>0)setTimeout(showLvlUp,80);
      else{frozen=false;gameState='playing';}
    };
    DOM.upgCards.appendChild(card);
  });
  showScreen('sLevelup');
}

// ─── Game Over ────────────────────────────────────────────────────
function endGame(){
  if(gameState==='gameover')return;
  gameState='gameover';frozen=false;
  sfx('gameover');stopMusic();
  SYNERGIES.forEach(s=>s.active=false);
  DOM.synNotif.style.display='none';
  const amber=Math.floor(score/100)+waveNum*5;
  saveData.amber+=amber;
  const newBest=score>saveData.bestScore;
  if(newBest)saveData.bestScore=score;
  if(gTime>saveData.bestTime)saveData.bestTime=gTime;
  saveData.totalRuns++;saveData.totalKills+=kills;
  if(!saveData.classBest[player.cls]||score>saveData.classBest[player.cls])saveData.classBest[player.cls]=score;
  writeSave();
  DOM.menuAmber.textContent=`⬡ AMBER: ${saveData.amber}`;
  const m=Math.floor(gTime/60),s=Math.floor(gTime%60);
  const title=kills>=100?'APEX PREDATOR':kills>=50?'WARRIOR':kills>=20?'FIGHTER':'CONSUMED';
  const titleCol=kills>=100?'#ffd700':kills>=50?'#ffaa00':kills>=20?'#88ffff':'#ff3333';
  DOM.goTitle.textContent=title;DOM.goTitle.style.color=titleCol;DOM.goTitle.style.textShadow=`0 0 28px ${titleCol}55`;
  DOM.goStats.innerHTML=`Survived: ${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}<br>Score: ${score.toLocaleString()}<br>Kills: ${kills.toLocaleString()}<br>Waves Cleared: ${waveNum}<br>Level Reached: ${player.lv}<br>Upgrades: ${Object.values(player.upgLv).reduce((a,b)=>a+b,0)}<br>Class: ${player.classDef.name}`;
  DOM.goBest.textContent=newBest?'★ NEW BEST SCORE ★':`Best: ${saveData.bestScore.toLocaleString()}`;
  DOM.goBest.style.color=newBest?'#ffd700':'#445566';
  DOM.goAmber.innerHTML=`+${amber} <span style="color:#ffaa00">AMBER</span> earned<br><span style="font-size:.8rem;color:#664400">Total: ${saveData.amber.toLocaleString()}</span>`;
  DOM.hud.style.display='none';DOM.abilInd.style.display='none';DOM.volHud.style.display='none';
  showScreen('sGameover');
}

// ─── Pause ────────────────────────────────────────────────────────
function togglePause(){
  if(gameState==='playing'){
    gameState='paused';frozen=true;
    const m=Math.floor(gTime/60),s=Math.floor(gTime%60);
    DOM.pauseStats.innerHTML=`Time: ${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')} &nbsp;·&nbsp; Wave: ${waveNum} &nbsp;·&nbsp; Score: ${score.toLocaleString()}<br>Kills: ${kills} &nbsp;·&nbsp; Level: ${player.lv} &nbsp;·&nbsp; Synergies: ${player.syns.size}`;
    showScreen('sPause');
  }else if(gameState==='paused'){
    gameState='playing';frozen=false;showScreen(null);
  }
}

// ─── RENDER ───────────────────────────────────────────────────────
function render(){
  const cw=canvas.width,ch=canvas.height;
  ctx.clearRect(0,0,cw,ch);
  ctx.save();ctx.translate(cw/2-cam.x+shake.x,ch/2-cam.y+shake.y);
  drawBg();drawGems();drawEnemies();drawParts();drawProjs();drawPlayer();drawDmgNums();drawAbilFx();
  ctx.restore();
  drawMinimap();
}

function drawBg(){
  ctx.fillStyle='#020408';ctx.fillRect(0,0,WORLD_WIDTH,WORLD_HEIGHT);
  ctx.strokeStyle='rgba(0,255,80,.02)';ctx.lineWidth=1;
  const gs=85;
  for(let x=0;x<WORLD_WIDTH;x+=gs){ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,WORLD_HEIGHT);ctx.stroke();}
  for(let y=0;y<WORLD_HEIGHT;y+=gs){ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(WORLD_WIDTH,y);ctx.stroke();}
  for(const s of bgDots){
    ctx.globalAlpha=.13+.2*Math.sin(gTime*s.fl+s.x*.01);ctx.fillStyle='#88ffcc';
    ctx.beginPath();ctx.arc(s.x,s.y,s.r,0,TAU);ctx.fill();
  }
  ctx.globalAlpha=1;
}

function drawPlayer(){
  const{x,y,classDef:c}=player;
  for(let i=0;i<player.trail.length;i++){const t=player.trail[i];ctx.globalAlpha=(1-i/player.trail.length)*.24;ctx.fillStyle=player.color;ctx.beginPath();ctx.arc(t.x,t.y,PLAYER_RADIUS*(1-i*.08),0,TAU);ctx.fill();}
  ctx.globalAlpha=1;
  if(player.invuln>0&&Math.floor(gTime*9)%2===0){ctx.globalAlpha=.5;ctx.strokeStyle='#fff';ctx.lineWidth=3;ctx.beginPath();ctx.arc(x,y,PLAYER_RADIUS+10,0,TAU);ctx.stroke();ctx.globalAlpha=1;}
  const g=ctx.createRadialGradient(x,y,0,x,y,PLAYER_RADIUS*3.2);
  g.addColorStop(0,`rgba(${c.glow},.33)`);g.addColorStop(1,`rgba(${c.glow},0)`);
  ctx.fillStyle=g;ctx.beginPath();ctx.arc(x,y,PLAYER_RADIUS*3.2,0,TAU);ctx.fill();
  ctx.shadowColor=player.color;ctx.shadowBlur=18;
  drawInsect(x,y,PLAYER_RADIUS,player.angle,player.cls,player.color);
  ctx.shadowBlur=0;
  if(player.syns.has('bladeStorm')){
    const ba=gTime*3;ctx.shadowColor='#ffaa00';ctx.shadowBlur=10;
    for(let i=0;i<6;i++){const a=ba+(i/6)*TAU;ctx.save();ctx.translate(x+Math.cos(a)*68,y+Math.sin(a)*68);ctx.rotate(a+Math.PI/4);ctx.fillStyle='#ffaa00';ctx.fillRect(-8,-2.5,16,5);ctx.restore();}
    ctx.shadowBlur=0;
  }
}

function drawInsect(x,y,r,ang,cls,col){
  ctx.save();ctx.translate(x,y);ctx.rotate(ang);
  switch(cls){
    case'mantis': ctx.fillStyle='#00ff88';ctx.beginPath();ctx.ellipse(0,0,r*.55,r*1.35,0,0,TAU);ctx.fill();ctx.fillStyle='#00cc66';ctx.save();ctx.rotate(-.55);ctx.fillRect(-r*1.9,-r*.3,r*1.5,r*.28);ctx.restore();ctx.save();ctx.rotate(.55);ctx.fillRect(r*.4,-r*.3,r*1.5,r*.28);ctx.restore();break;
    case'scarab': ctx.fillStyle='#ffd700';ctx.beginPath();ctx.arc(0,0,r,0,TAU);ctx.fill();ctx.fillStyle='#aa8800';ctx.beginPath();ctx.ellipse(0,0,r*.55,r*.48,0,0,TAU);ctx.fill();ctx.fillStyle='#ffd700';ctx.fillRect(r*.78,-r*.2,r*.9,r*.38);break;
    case'widow':  ctx.fillStyle='#ff0066';ctx.beginPath();ctx.arc(0,0,r*.82,0,TAU);ctx.fill();ctx.fillStyle='#bb0044';ctx.beginPath();ctx.arc(r*.5,0,r*.48,0,TAU);ctx.fill();ctx.strokeStyle='#ff0066';ctx.lineWidth=2;for(let i=0;i<4;i++){const a=(i/4)*Math.PI-Math.PI/2;ctx.beginPath();ctx.moveTo(0,0);ctx.lineTo(Math.cos(a)*r*2.1,Math.sin(a)*r*2.1);ctx.stroke();ctx.beginPath();ctx.moveTo(0,0);ctx.lineTo(-Math.cos(a)*r*2.1,-Math.sin(a)*r*2.1);ctx.stroke();}break;
    case'wasp':   ctx.fillStyle='#ffaa00';ctx.beginPath();ctx.ellipse(0,0,r*.65,r*1.25,0,0,TAU);ctx.fill();ctx.fillStyle='rgba(0,0,0,.7)';for(let i=-2;i<=2;i++)ctx.fillRect(-r*.65,i*r*.4,r*1.3,r*.22);ctx.globalAlpha=.45;ctx.fillStyle='#aaffee';ctx.beginPath();ctx.ellipse(-r,-.25*r,r*.8,r*.38,-.4,0,TAU);ctx.fill();ctx.beginPath();ctx.ellipse(r,-.25*r,r*.8,r*.38,.4,0,TAU);ctx.fill();ctx.globalAlpha=1;break;
    case'moth':   ctx.fillStyle='#aa88ff';ctx.beginPath();ctx.ellipse(0,0,r*.45,r*1.05,0,0,TAU);ctx.fill();ctx.globalAlpha=.68;ctx.fillStyle='#aa88ff';ctx.beginPath();ctx.ellipse(-r*1.15,0,r,r*.58,-.3,0,TAU);ctx.fill();ctx.beginPath();ctx.ellipse(r*1.15,0,r,r*.58,.3,0,TAU);ctx.fill();ctx.globalAlpha=.48;ctx.fillStyle='#6644cc';ctx.beginPath();ctx.ellipse(-r*.85,r*.6,r*.58,r*.38,-.5,0,TAU);ctx.fill();ctx.beginPath();ctx.ellipse(r*.85,r*.6,r*.58,r*.38,.5,0,TAU);ctx.fill();ctx.globalAlpha=1;break;
    default:      ctx.fillStyle=col;ctx.beginPath();ctx.arc(0,0,r,0,TAU);ctx.fill();
  }
  ctx.fillStyle='#000';ctx.beginPath();ctx.arc(-r*.24,-r*.58,r*.19,0,TAU);ctx.fill();ctx.beginPath();ctx.arc(r*.24,-r*.58,r*.19,0,TAU);ctx.fill();
  ctx.fillStyle=player&&player.syns.size>0?'#ff2200':'#fff';ctx.beginPath();ctx.arc(-r*.21,-r*.6,r*.08,0,TAU);ctx.fill();ctx.beginPath();ctx.arc(r*.21,-r*.6,r*.08,0,TAU);ctx.fill();
  ctx.restore();
}

function drawEnemies(){
  for(const e of enemies){
    if(e.dead)continue;
    const{x,y,r,col,hp,maxHp,flashT,elite,type,isBoss}=e;
    if(isBoss){ctx.globalAlpha=(.4+.3*Math.sin(gTime*3))*.45;ctx.strokeStyle=col;ctx.lineWidth=4;ctx.beginPath();ctx.arc(x,y,r*1.6+8*Math.sin(gTime*5),0,TAU);ctx.stroke();ctx.globalAlpha=1;}
    if(elite||isBoss){const gg=ctx.createRadialGradient(x,y,0,x,y,r*2.5);gg.addColorStop(0,col+'44');gg.addColorStop(1,col+'00');ctx.fillStyle=gg;ctx.beginPath();ctx.arc(x,y,r*2.5,0,TAU);ctx.fill();}
    ctx.shadowColor=col;ctx.shadowBlur=(elite||isBoss)?14:4;
    ctx.fillStyle=flashT>0?'#fff':col;
    ctx.beginPath();
    if(type==='ant'||type==='beetle')ctx.ellipse(x,y,r,r*1.28,0,0,TAU);
    else if(type==='hornet')ctx.ellipse(x,y,r*.78,r*1.38,0,0,TAU);
    else if(isBoss){ctx.arc(x,y,r,0,TAU);ctx.fill();ctx.beginPath();ctx.arc(x-r*.8,y,r*.65,0,TAU);ctx.fill();ctx.beginPath();ctx.arc(x+r*.8,y,r*.65,0,TAU);}
    else ctx.arc(x,y,r,0,TAU);
    ctx.fill();ctx.shadowBlur=0;
    if(hp<maxHp){const bw=isBoss?r*3:r*2.6,bh=isBoss?6:3,bx=x-bw/2,by=y-r-(isBoss?14:8);ctx.fillStyle='rgba(255,0,0,.4)';ctx.fillRect(bx,by,bw,bh);ctx.fillStyle=isBoss?'#ff4400':elite?'#ffd700':'#00ff66';ctx.fillRect(bx,by,bw*(hp/maxHp),bh);}
    if(isBoss){ctx.fillStyle='#fff';ctx.font='bold 11px Share Tech Mono,monospace';ctx.textAlign='center';ctx.fillText('HIVE MOTHER',x,y-r-16);}
    if(e.poisonT>0){ctx.strokeStyle='#00ff44';ctx.lineWidth=2;ctx.beginPath();ctx.arc(x,y,r+4,0,TAU*(e.poisonT/5));ctx.stroke();}
    if(type==='shaman'){ctx.strokeStyle='rgba(204,0,255,.28)';ctx.lineWidth=1;ctx.beginPath();ctx.arc(x,y,148,0,TAU);ctx.stroke();}
  }
}

function drawGems(){
  for(const g of gems){
    const bob=Math.sin(g.bob)*2.2;ctx.shadowColor=g.col;ctx.shadowBlur=12;ctx.fillStyle=g.col;
    ctx.save();ctx.translate(g.x,g.y+bob);ctx.rotate(Math.PI/4+gTime*.55);ctx.fillRect(-g.r,-g.r,g.r*2,g.r*2);ctx.restore();
    ctx.fillStyle='rgba(255,255,255,.5)';ctx.save();ctx.translate(g.x-g.r*.2,g.y+bob-g.r*.2);ctx.rotate(Math.PI/4+gTime*.55);ctx.fillRect(-g.r*.28,-g.r*.28,g.r*.55,g.r*.55);ctx.restore();
    ctx.shadowBlur=0;
  }
}

function drawProjs(){
  for(const p of projs){
    if(p.dead)continue;
    for(let i=0;i<p.trail.length;i++){ctx.globalAlpha=(1-i/p.trail.length)*.32;ctx.fillStyle=p.col;ctx.beginPath();ctx.arc(p.trail[i].x,p.trail[i].y,p.r*(1-i*.14),0,TAU);ctx.fill();}
    ctx.globalAlpha=1;ctx.shadowColor=p.col;ctx.shadowBlur=11;ctx.fillStyle=p.col;ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,TAU);ctx.fill();
    ctx.fillStyle='rgba(255,255,255,.7)';ctx.beginPath();ctx.arc(p.x,p.y,p.r*.36,0,TAU);ctx.fill();ctx.shadowBlur=0;
  }
}

function drawParts(){
  for(const p of parts){ctx.globalAlpha=p.life/p.maxLife;ctx.shadowColor=p.col;ctx.shadowBlur=4;ctx.fillStyle=p.col;ctx.beginPath();ctx.arc(p.x,p.y,p.sz,0,TAU);ctx.fill();}
  ctx.globalAlpha=1;ctx.shadowBlur=0;
}

function drawDmgNums(){
  ctx.textAlign='center';
  for(const d of dmgNums){ctx.globalAlpha=d.life/d.maxLife;ctx.font=`bold ${d.big?14:11}px 'Share Tech Mono',monospace`;ctx.fillStyle=d.col;ctx.shadowColor=d.col;ctx.shadowBlur=6;ctx.fillText(d.val,d.x,d.y);}
  ctx.globalAlpha=1;ctx.shadowBlur=0;
}

function drawAbilFx(){
  if(!abilFx)return;
  ctx.globalAlpha=abilFx.life/abilFx.maxLife;
  switch(abilFx.type){
    case'lightning': ctx.strokeStyle='#00ff88';ctx.lineWidth=3;ctx.shadowColor='#00ff88';ctx.shadowBlur=20;ctx.beginPath();ctx.moveTo(abilFx.x,abilFx.y);for(let i=1;i<=10;i++){const f=i/10;ctx.lineTo(abilFx.x+(abilFx.tx-abilFx.x)*f+(random()-.5)*18,abilFx.y+(abilFx.ty-abilFx.y)*f+(random()-.5)*18);}ctx.stroke();break;
    case'cloud':case'dust':{const c=abilFx.type==='cloud'?'#ff0066':'#aa88ff';ctx.strokeStyle=c;ctx.lineWidth=2;ctx.shadowColor=c;ctx.shadowBlur=20;ctx.beginPath();ctx.arc(abilFx.x,abilFx.y,abilFx.r*(1-abilFx.life/abilFx.maxLife),0,TAU);ctx.stroke();break;}
    case'shield': ctx.strokeStyle='#ffd700';ctx.lineWidth=4;ctx.shadowColor='#ffd700';ctx.shadowBlur=26;ctx.beginPath();ctx.arc(abilFx.x,abilFx.y,abilFx.r,0,TAU);ctx.stroke();break;
  }
  ctx.globalAlpha=1;ctx.shadowBlur=0;
}

function drawMinimap(){
  const ms=115,mp=14,mx=canvas.width-ms-mp,my=canvas.height-ms-mp;
  const sx=ms/WORLD_WIDTH,sy=ms/WORLD_HEIGHT;
  ctx.globalAlpha=.7;ctx.fillStyle='rgba(0,0,0,.6)';ctx.fillRect(mx,my,ms,ms);
  ctx.strokeStyle='rgba(0,255,80,.22)';ctx.lineWidth=1;ctx.strokeRect(mx,my,ms,ms);
  for(const e of enemies)if(!e.dead){ctx.fillStyle=e.isBoss?'#ff2200':'#ff4444';ctx.fillRect(mx+e.x*sx-(e.isBoss?2:1),my+e.y*sy-(e.isBoss?2:1),e.isBoss?4:2,e.isBoss?4:2);}
  ctx.shadowColor=player.color;ctx.shadowBlur=6;ctx.fillStyle=player.color;ctx.beginPath();ctx.arc(mx+player.x*sx,my+player.y*sy,3.5,0,TAU);ctx.fill();ctx.shadowBlur=0;ctx.globalAlpha=1;
}

// ─── Menu Background ──────────────────────────────────────────────
let menuRaf=false;
function menuBg(ts){
  if(gameState!=='menu'&&gameState!=='classSelect'&&gameState!=='htp'&&gameState!=='settings'&&gameState!=='records'){menuRaf=false;return;}
  ctx.fillStyle='#020408';ctx.fillRect(0,0,canvas.width,canvas.height);
  const t=ts/1000;
  for(let i=0;i<bgDots.length;i++){
    const s=bgDots[i];
    ctx.globalAlpha=.1+.2*Math.sin(t*s.fl+i);
    ctx.fillStyle=i%3===0?'#00ff88':i%3===1?'#ffd700':'#ff0066';
    ctx.beginPath();ctx.arc((s.x+t*18*(i%3+.5))%canvas.width,(s.y+t*9*(i%2+.35))%canvas.height,s.r+.4,0,TAU);ctx.fill();
  }
  ctx.globalAlpha=1;requestAnimationFrame(menuBg);
}
function startMenuBg(){if(!menuRaf){menuRaf=true;requestAnimationFrame(menuBg);}}
startMenuBg();

// ─── Game Loop ────────────────────────────────────────────────────
function loop(ts){
  const dt=Math.min((ts-lastTS)/1000,.05);lastTS=ts;
  if(gameState==='playing'||gameState==='levelup'){update(dt);render();}
  rafId=requestAnimationFrame(loop);
}

// ─── Start Game ───────────────────────────────────────────────────
function startGame(cls){
  initAudio();resumeAX();
  enemies=[];projs=[];gems=[];parts=[];dmgNums=[];abilFx=null;bossActive=false;
  gTime=0;score=0;kills=0;waveNum=1;waveT=0;spawnT=0;spawnI=1.5;liveEnemyCount=0;
  lvlPending=0;synQueue=[];synT=0;killStreak=0;streakT=0;frozen=false;
  _lHp=-1;_lXp=-1;_lSc=-1;_lCd=-1;_lStr=-1;_lSyn=-1;
  SYNERGIES.forEach(s=>s.active=false);
  player=mkPlayer(cls);cam.x=player.x;cam.y=player.y;
  DOM.hud.style.display='block';DOM.abilInd.style.display='block';
  DOM.volHud.style.display='block';
  DOM.synNotif.style.display='none';DOM.waveBanner.style.display='none';
  gameState='playing';showScreen(null);
  startMusic();
  if(rafId)cancelAnimationFrame(rafId);
  rafId=requestAnimationFrame(ts=>{lastTS=ts;rafId=requestAnimationFrame(loop);});
}

